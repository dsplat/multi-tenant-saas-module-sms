{
    "name": "dsplat/multi-tenant-saas-module-sms",
    "version": "1.0.0",
    "description": "短信服务 - 模板管理、批量发送、到达率统计、退订管理",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "MultiTenantSaas\\Modules\\Sms\\": ""
        }
    },
    "require": {
        "php": "^8.3",
        "dsplat/multi-tenant-saas": "^2.0"
    },
    "extra": {
        "saas": {
            "name": "sms",
            "priority": 300,
            "dependencies": [],
            "conflicts": [],
            "requires_core": ">=1.0.0",
            "provider": "MultiTenantSaas\\Modules\\Sms\\SmsServiceProvider",
            "tenant_toggleable": true,
            "default_enabled": true
        }
    }
}
